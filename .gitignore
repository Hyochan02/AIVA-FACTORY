# =========================================================
# AIVA FACTORY · .gitignore
# =========================================================

# ── 의존성 패키지 (용량이 크므로 절대 커밋 금지) ────────────
node_modules/

# ── 빌드 결과물 ───────────────────────────────────────────
dist/
build/
aiva-backend/dist/

# ── 환경변수 (비밀키 포함 → 절대 커밋 금지!) ───────────────
.env
.env.local
.env.production
.env.*.local
# example 파일은 커밋 허용 (실제 값 없음)
!.env.example
!.env.production.example

# ── 로그 파일 ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS 자동 생성 파일 ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 에디터 설정 ───────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Docker 관련 ───────────────────────────────────────────
# nginx/html 은 CI에서 배포 시 생성되므로 제외
aiva-backend/nginx/html/

# ── TypeScript 캐시 ───────────────────────────────────────
*.tsbuildinfo

# ── 오래된 프로토타입 폴더 (불필요) ───────────────────────
tasks
