# =========================================================
# AIVA FACTORY · 프로덕션 환경변수 (EC2에 .env.production 으로 저장)
# 이 파일을 EC2 서버에 복사: /home/ubuntu/aiva-factory/.env.production
# 절대 git에 커밋하지 마세요!
# =========================================================

# ── 서버 ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── JWT ───────────────────────────────────────────────────
# 생성: openssl rand -base64 64
JWT_SECRET=여기에_랜덤_64바이트_문자열
JWT_EXPIRES_IN=7d

# ── MySQL (Docker 서비스명 사용 → RDS 불필요!) ────────────
# docker-compose.prod.yml 의 mysql 서비스명이 곧 hostname
DB_HOST=mysql
DB_PORT=3306
DB_USER=aiva_user
DB_PASSWORD=강력한_DB_비밀번호_입력
DB_ROOT_PASSWORD=강력한_ROOT_비밀번호_입력
DB_NAME=aiva_factory

DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@mysql:3306/${DB_NAME}"

# ── Suno AI ───────────────────────────────────────────────
SUNO_API_KEY=suno_api_key_여기에_입력
SUNO_API_BASE_URL=https://api.suno.ai

# ── AWS S3 (오디오 파일 저장) ─────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIA_여기에_입력
AWS_SECRET_ACCESS_KEY=여기에_입력
AWS_S3_BUCKET=aiva-factory-audio

# ── CORS ──────────────────────────────────────────────────
# EC2 IP 또는 도메인으로 교체
ALLOWED_ORIGINS=http://your-ec2-ip,https://your-domain.com

# ── GitHub Container Registry (docker-compose.prod.yml 참조) ─
# 예: myusername/aiva-factory
GITHUB_REPOSITORY=your-github-username/your-repo-name
